source "https://rubygems.org"

# GitHub Pages 호환 빌드. 로컬 미리보기/원격 빌드 모두 이 gem 묶음으로 동작.
gem "github-pages", "~> 231", group: :jekyll_plugins

group :jekyll_plugins do
  gem "jekyll-remote-theme"
  gem "jekyll-seo-tag"
  gem "jekyll-include-cache"
end

# 로컬(Ruby 3+) 미리보기용 보정 — GitHub Pages 빌드 환경엔 영향 없음
gem "webrick", "~> 1.8"
gem "rexml", "~> 3.2"
